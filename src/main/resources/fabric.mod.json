{
  "schemaVersion": 1,
  "id": "goranime",
  "version": "${version}",
  "name": "GoranIME",
  "description": "CJK input for all platforms",
  "authors": [
    {
      "name": "Blue_ON",
      "contact": {
        "sources": "https://github.com/wb1016/GoranIME"
      }
    }
  ],
  "contact": {
    "homepage": "https://github.com/wb1016/GoranIME",
    "sources": "https://github.com/wb1016/GoranIME",
    "issues": "https://github.com/wb1016/GoranIME/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/goranime/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["dev.blueon.goranime.client.GoranimeFabricClientMod"],
    "modmenu": ["dev.blueon.goranime.client.GoranimeModMenuIntegration"],
    "sodium:config_api_user": [
      "dev.blueon.goranime.client.integration.sodium.GoranimeSodiumConfigBuilder"
    ]
  },
  "mixins": ["goranime.mixins.json"],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_version}",
    "yet_another_config_lib_v3": "*"
  },
  "suggests": {
    "modmenu": "*",
    "sodium": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.donate": "https://buymeacoffee.com/wb1016",
        "modmenu.github": "https://github.com/wb1016/goranime",
        "modmenu.modrinth": "https://modrinth.com/mod/goranime"
      }
    }
  }
}
