{
  "schemaVersion": 1,
  "id": "goranime",
  "version": "${version}",
  "name": "GoranIME",
  "description": "Korean input support for Minecraft on all platforms. Uses manual Hangul composition (dubeolsik) that works on Linux, macOS, and Windows.",
  "authors": [
    {
      "name": "blueon",
      "contact": {
        "sources": "https://github.com/blueon/goranime"
      }
    }
  ],
  "contact": {
    "homepage": "https://github.com/blueon/goranime",
    "sources": "https://github.com/blueon/goranime",
    "issues": "https://github.com/blueon/goranime/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/goranime/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["dev.blueon.goranime.client.GoranimeFabricClientMod"],
    "modmenu": ["dev.blueon.goranime.client.GoranimeModMenuIntegration"],
    "sodium:config_api_user": [
      "dev.blueon.goranime.client.integration.sodium.GoranimeSodiumConfigBuilder"
    ]
  },
  "mixins": ["goranime.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": ">=26.1",
    "fabric-api": "*",
    "yet_another_config_lib_v3": "*"
  },
  "suggests": {
    "modmenu": "*",
    "sodium": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github": "https://github.com/blueon/goranime"
      }
    }
  }
}
